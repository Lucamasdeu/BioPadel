<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Reservas — BioPadel</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet"/>
<style>
  :root {
    --green: #1a3d2b;
    --green-mid: #2d6a4f;
    --green-light: #52b788;
    --green-pale: #d8f3dc;
    --accent: #f4a261;
    --accent-dark: #e76f51;
    --bg: #f8f7f4;
    --card: #ffffff;
    --text: #1a1a1a;
    --text-muted: #6b7280;
    --border: rgba(0,0,0,0.08);
    --radius: 14px;
    --radius-sm: 8px;
    --shadow: 0 2px 16px rgba(0,0,0,0.07);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.12);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: var(--green);
    color: white;
    padding: 0 24px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2);
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-icon {
    width: 32px;
    height: 32px;
    background: var(--green-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }
  .logo-text {
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    letter-spacing: -0.3px;
  }
  .logo-sub {
    font-size: 11px;
    opacity: 0.6;
    margin-top: -2px;
  }
  .nav-tabs {
    display: flex;
    gap: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 4px;
  }
  .nav-tab {
    padding: 6px 16px;
    border: none;
    background: none;
    color: rgba(255,255,255,0.7);
    border-radius: 7px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }
  .nav-tab.active {
    background: white;
    color: var(--green);
  }
  .nav-tab:hover:not(.active) { color: white; background: rgba(255,255,255,0.15); }

  /* MAIN LAYOUT */
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 24px 60px;
  }
  .view { display: none; }
  .view.active { display: block; }

  /* SECTION LABELS */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  /* COURTS */
  .courts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .court-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: var(--shadow);
  }
  .court-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .court-card.selected {
    border-color: var(--green-mid);
    background: linear-gradient(135deg, #f0faf4 0%, #e8f5ee 100%);
    box-shadow: 0 4px 20px rgba(45,106,79,0.15);
  }
  .court-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 10px;
  }
  .court-icon.indoor { background: #e8f4fd; }
  .court-icon.outdoor { background: #edf7ed; }
  .court-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .court-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
  .court-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    margin-top: 8px;
  }
  .badge-in { background: #dbeafe; color: #1d4ed8; }
  .badge-out { background: #dcfce7; color: #15803d; }
  .court-price { font-size: 12px; color: var(--text-muted); margin-top: 6px; line-height: 1.5; }
  .selected-check {
    float: right;
    width: 20px;
    height: 20px;
    background: var(--green-mid);
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 12px;
  }
  .court-card.selected .selected-check { display: flex; }

  /* CALENDAR */
  .cal-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .week-nav {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .week-btn {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: var(--card);
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    font-family: inherit;
    color: var(--text);
  }
  .week-btn:hover { background: var(--green); color: white; border-color: var(--green); }
  .week-label { font-size: 14px; font-weight: 500; color: var(--text); min-width: 160px; text-align: center; }

  .cal-grid {
    background: var(--card);
    border-radius: var(--radius);
    border: 1.5px solid var(--border);
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-bottom: 32px;
  }
  .cal-days-row {
    display: grid;
    grid-template-columns: 72px repeat(7, 1fr);
    background: var(--green);
  }
  .cal-day-hdr {
    padding: 10px 4px;
    text-align: center;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }
  .cal-day-hdr.today { color: white; font-weight: 700; }
  .cal-day-hdr.today span {
    background: var(--accent);
    color: white;
    border-radius: 6px;
    padding: 2px 6px;
  }
  .cal-body {}
  .cal-row {
    display: grid;
    grid-template-columns: 72px repeat(7, 1fr);
    border-top: 1px solid var(--border);
  }
  .cal-row:first-child { border-top: none; }
  .time-lbl {
    padding: 0 10px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    background: #fafafa;
    border-right: 1px solid var(--border);
  }
  .time-lbl span { font-size: 12px; color: var(--text-muted); font-weight: 500; }
  .time-lbl small { font-size: 10px; color: #aaa; }
  .slot-cell {
    padding: 4px;
    border-left: 1px solid var(--border);
    min-height: 52px;
  }
  .slot-btn {
    width: 100%;
    height: 100%;
    min-height: 44px;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 11px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    transition: all 0.15s;
    background: #f0fdf4;
    color: var(--green-mid);
  }
  .slot-btn:hover { background: var(--green-mid); color: white; transform: scale(0.97); }
  .slot-btn.sel { background: var(--green); color: white; }
  .slot-btn.taken { background: #f3f4f6; color: #d1d5db; cursor: not-allowed; font-size: 10px; }
  .slot-btn.past { background: transparent; color: #e5e7eb; cursor: not-allowed; font-size: 11px; }

  /* BOOKING FORM */
  .booking-card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1.5px solid var(--border);
    padding: 24px;
    box-shadow: var(--shadow);
  }
  .booking-summary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .sum-chip {
    background: var(--bg);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
  }
  .sum-chip-lbl { font-size: 11px; color: var(--text-muted); margin-bottom: 2px; font-weight: 500; }
  .sum-chip-val { font-size: 14px; font-weight: 600; color: var(--text); }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 20px;
  }
  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label { font-size: 12px; font-weight: 500; color: var(--text-muted); }
  .field input {
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    background: var(--bg);
    color: var(--text);
    transition: border-color 0.15s;
  }
  .field input:focus { border-color: var(--green-mid); background: white; }
  .price-total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-top: 1px dashed var(--border);
    margin-bottom: 16px;
  }
  .price-total-lbl { font-size: 14px; color: var(--text-muted); }
  .price-total-bk { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
  .price-total-val { font-size: 24px; font-weight: 700; color: var(--green); }
  .price-total-cur { font-size: 13px; color: var(--text-muted); }
  .pay-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .pay-btn {
    padding: 14px;
    border-radius: var(--radius);
    border: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .pay-btn:active { transform: scale(0.98); }
  .pay-mp { background: #009ee3; color: white; }
  .pay-mp:hover { background: #007ec0; }
  .pay-cash { background: var(--green); color: white; }
  .pay-cash:hover { background: var(--green-mid); }

  /* SUCCESS */
  .success-card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1.5px solid #86efac;
    padding: 32px 24px;
    text-align: center;
    box-shadow: var(--shadow);
    display: none;
    margin-top: 0;
  }
  .success-icon {
    width: 56px;
    height: 56px;
    background: var(--green-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    margin: 0 auto 16px;
  }
  .success-title { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--green); margin-bottom: 6px; }
  .success-detail { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; }
  .notif-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .notif-btn {
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--border);
    background: var(--card);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
  }
  .notif-btn:hover { background: var(--bg); border-color: var(--green-mid); color: var(--green); }
  .notif-btn.wa { border-color: #25d366; color: #128c7e; }
  .notif-btn.wa:hover { background: #f0fdf4; }

  /* ADMIN */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: var(--card);
    border-radius: var(--radius);
    padding: 16px 18px;
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow);
  }
  .stat-lbl { font-size: 12px; color: var(--text-muted); font-weight: 500; margin-bottom: 4px; }
  .stat-val { font-size: 26px; font-weight: 700; color: var(--green); }
  .stat-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .filters {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    align-items: center;
  }
  .filters select, .filters input[type=date] {
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    background: var(--card);
    color: var(--text);
    outline: none;
    cursor: pointer;
  }
  .filters select:focus, .filters input:focus { border-color: var(--green-mid); }
  .clear-btn {
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--border);
    background: none;
    font-size: 13px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    color: var(--text-muted);
  }
  .clear-btn:hover { border-color: var(--green-mid); color: var(--green); }
  .res-list { display: flex; flex-direction: column; gap: 10px; }
  .res-item {
    background: var(--card);
    border-radius: var(--radius);
    border: 1.5px solid var(--border);
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s;
  }
  .res-item:hover { box-shadow: var(--shadow-lg); }
  .res-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--green-pale);
    color: var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }
  .res-info { flex: 1; min-width: 0; }
  .res-name { font-size: 14px; font-weight: 600; color: var(--text); }
  .res-meta { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
  .res-right { text-align: right; flex-shrink: 0; }
  .res-price { font-size: 15px; font-weight: 700; color: var(--green); }
  .res-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 20px;
    margin-top: 4px;
  }
  .badge-mp { background: #dbeafe; color: #1d4ed8; }
  .badge-cash { background: var(--green-pale); color: var(--green); }
  .res-actions { display: flex; gap: 6px; margin-top: 6px; justify-content: flex-end; }
  .res-action-btn {
    width: 30px;
    height: 30px;
    border-radius: 7px;
    border: 1.5px solid var(--border);
    background: none;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    text-decoration: none;
  }
  .res-action-btn:hover { background: var(--bg); }
  .res-action-btn.danger:hover { background: #fef2f2; border-color: #fca5a5; color: #dc2626; }
  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--text-muted);
    background: var(--card);
    border-radius: var(--radius);
    border: 1.5px solid var(--border);
  }
  .empty-state-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-state p { font-size: 14px; }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--green) 0%, var(--green-mid) 100%);
    border-radius: var(--radius);
    padding: 28px 32px;
    color: white;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .hero-title { font-family: 'DM Serif Display', serif; font-size: 26px; margin-bottom: 4px; }
  .hero-sub { font-size: 14px; opacity: 0.8; }
  .hero-pills { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
  .hero-pill {
    background: rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
  }
  .hero-right { font-size: 48px; opacity: 0.3; flex-shrink: 0; }

  @media (max-width: 640px) {
    main { padding: 20px 16px 48px; }
    .courts-grid { grid-template-columns: 1fr; }
    .cal-days-row, .cal-row { grid-template-columns: 56px repeat(7, 1fr); }
    .booking-summary { grid-template-columns: 1fr; }
    .form-grid { grid-template-columns: 1fr; }
    .pay-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .hero { flex-direction: column; }
    .hero-right { display: none; }
    .nav-tab { padding: 6px 10px; font-size: 12px; }
  }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo">
      <div class="logo-icon">🎾</div>
      <div>
        <div class="logo-text">BioPadel</div>
        <div class="logo-sub">Sistema de reservas</div>
      </div>
    </div>
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="switchView('reservar', this)">🎾 Reservar</button>
      <button class="nav-tab" onclick="switchView('admin', this)">⚙️ Admin</button>
    </div>
  </div>
</header>

<main>

  <!-- VISTA RESERVAR -->
  <div id="view-reservar" class="view active">
    <div class="hero">
      <div>
        <div class="hero-title">Reservá tu cancha</div>
        <div class="hero-sub">Elegí cancha, día y horario — confirmación instantánea</div>
        <div class="hero-pills">
          <span class="hero-pill">📅 Turnos de 1h 30min</span>
          <span class="hero-pill">⏰ 14:30 a 22:00</span>
          <span class="hero-pill">💳 MercadoPago o efectivo</span>
        </div>
      </div>
      <div class="hero-right">🎾</div>
    </div>

    <p class="section-label">1 · Elegí la cancha</p>
    <div class="courts-grid" id="courts-grid">
      <div class="court-card selected" data-id="1" data-name="Cancha 1" data-type="indoor" onclick="selectCourt(this)">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div class="court-icon indoor">🏟️</div>
          <div class="selected-check">✓</div>
        </div>
        <div class="court-name">Cancha 1</div>
        <div class="court-sub">Vidrio completo</div>
        <span class="court-badge badge-in">Indoor</span>
        <div class="court-price">$300 por persona<br><strong>$1.200 total</strong></div>
      </div>
      <div class="court-card" data-id="2" data-name="Cancha 2" data-type="indoor" onclick="selectCourt(this)">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div class="court-icon indoor">🏟️</div>
          <div class="selected-check">✓</div>
        </div>
        <div class="court-name">Cancha 2</div>
        <div class="court-sub">Vidrio completo</div>
        <span class="court-badge badge-in">Indoor</span>
        <div class="court-price">$300 por persona<br><strong>$1.200 total</strong></div>
      </div>
      <div class="court-card" data-id="3" data-name="Cancha 3" data-type="outdoor" onclick="selectCourt(this)">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div class="court-icon outdoor">🌿</div>
          <div class="selected-check">✓</div>
        </div>
        <div class="court-name">Cancha 3</div>
        <div class="court-sub">Panorámica</div>
        <span class="court-badge badge-out">Outdoor</span>
        <div class="court-price">$260/p · <strong>$1.040</strong> Lun–Vie<br>$200/p · <strong>$800</strong> Sáb–Dom</div>
      </div>
    </div>

    <div class="cal-header-row">
      <p class="section-label" style="margin:0">2 · Elegí el horario</p>
      <div class="week-nav">
        <button class="week-btn" onclick="changeWeek(-1)">‹</button>
        <span class="week-label" id="week-lbl"></span>
        <button class="week-btn" onclick="changeWeek(1)">›</button>
      </div>
    </div>

    <div class="cal-grid">
      <div class="cal-days-row" id="cal-days-row"></div>
      <div class="cal-body" id="cal-body"></div>
    </div>

    <p class="section-label">3 · Tus datos y pago</p>
    <div class="booking-card" id="booking-card">
      <div class="booking-summary">
        <div class="sum-chip">
          <div class="sum-chip-lbl">Cancha</div>
          <div class="sum-chip-val" id="s-court">Cancha 1 — Indoor</div>
        </div>
        <div class="sum-chip">
          <div class="sum-chip-lbl">Fecha</div>
          <div class="sum-chip-val" id="s-date">Elegí un día →</div>
        </div>
        <div class="sum-chip">
          <div class="sum-chip-lbl">Turno</div>
          <div class="sum-chip-val" id="s-time">—</div>
        </div>
      </div>
      <div class="form-grid">
        <div class="field">
          <label>Nombre completo</label>
          <input type="text" id="i-name" placeholder="Ej: Juan Pérez"/>
        </div>
        <div class="field">
          <label>Teléfono / WhatsApp</label>
          <input type="tel" id="i-phone" placeholder="+598 9X XXX XXX"/>
        </div>
        <div class="field">
          <label>Email</label>
          <input type="email" id="i-email" placeholder="correo@ejemplo.com"/>
        </div>
        <div class="field">
          <label>Compañeros (opcional)</label>
          <input type="text" id="i-players" placeholder="Nombre de los otros jugadores"/>
        </div>
      </div>
      <div class="price-total">
        <div>
          <div class="price-total-lbl">Total a pagar</div>
          <div class="price-total-bk" id="s-bk">$300 × 4 personas</div>
        </div>
        <div style="text-align:right">
          <span class="price-total-val" id="s-price">$1.200</span>
          <span class="price-total-cur"> UYU</span>
        </div>
      </div>
      <div class="pay-grid">
        <button class="pay-btn pay-mp" onclick="doBooking('mp')">
          💳 Pagar con MercadoPago
        </button>
        <button class="pay-btn pay-cash" onclick="doBooking('cash')">
          💵 Pagar en la cancha
        </button>
      </div>
    </div>

    <div class="success-card" id="success-card">
      <div class="success-icon">✅</div>
      <div class="success-title" id="ok-title">¡Reserva confirmada!</div>
      <div class="success-detail" id="ok-detail"></div>
      <div class="notif-row" id="notif-row"></div>
    </div>
  </div>

  <!-- VISTA ADMIN -->
  <div id="view-admin" class="view">
    <div class="stats-row" id="stats-row"></div>
    <div class="filters">
      <select id="f-court" onchange="renderAdmin()">
        <option value="">Todas las canchas</option>
        <option value="1">Cancha 1</option>
        <option value="2">Cancha 2</option>
        <option value="3">Cancha 3</option>
      </select>
      <select id="f-pay" onchange="renderAdmin()">
        <option value="">Todos los pagos</option>
        <option value="mp">MercadoPago</option>
        <option value="cash">En cancha</option>
      </select>
      <input type="date" id="f-date" onchange="renderAdmin()"/>
      <button class="clear-btn" onclick="clearFilters()">Limpiar filtros</button>
    </div>
    <div class="res-list" id="res-list"></div>
  </div>

</main>

<script>
const DAYS=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
const MONTHS=['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const SLOTS=[
  {s:'14:30',e:'16:00'},
  {s:'16:00',e:'17:30'},
  {s:'17:30',e:'19:00'},
  {s:'19:00',e:'20:30'},
  {s:'20:30',e:'22:00'}
];
const WA_ADMIN='+59899000000'; // ← CAMBIÁ por tu número

let weekOff=0, selSlot=null;
let selCourt={id:'1',name:'Cancha 1',type:'indoor'};
let reservas=[];

function storageGet(k){try{return JSON.parse(localStorage.getItem(k));}catch(e){return null;}}
function storageSet(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}

function loadReservas(){
  reservas=storageGet('padel_reservas')||[];
}
function saveReservas(){
  storageSet('padel_reservas',reservas);
}

function isWE(d){return d.getDay()===0||d.getDay()===6;}
function getPrice(type,d){if(type==='indoor')return 1200;return isWE(d)?800:1040;}
function getBk(type,d){if(type==='indoor')return '$300 × 4 personas';return isWE(d)?'$200 × 4 personas · fin de semana':'$260 × 4 personas · lunes a viernes';}
function dk(d){const y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,'0'),day=String(d.getDate()).padStart(2,'0');return y+'-'+m+'-'+day;}
function isTaken(d,si,courtId){const key=dk(d)+'_s'+si+'_c'+(courtId||selCourt.id);return reservas.some(r=>r.key===key&&!r.cancelled);}
function isPast(d,si){const now=new Date();const[h,m]=SLOTS[si].s.split(':').map(Number);const t=new Date(d);t.setHours(h,m,0,0);return t<now;}

function getWeekDays(off){
  const now=new Date();const dow=now.getDay();
  const mon=new Date(now);mon.setDate(now.getDate()-(dow===0?6:dow-1)+off*7);
  return Array.from({length:7},(_,i)=>{const d=new Date(mon);d.setDate(mon.getDate()+i);return d;});
}

function renderCal(){
  const days=getWeekDays(weekOff);
  document.getElementById('week-lbl').textContent=
    days[0].getDate()+' '+MONTHS[days[0].getMonth()].slice(0,3)+' – '+
    days[6].getDate()+' '+MONTHS[days[6].getMonth()].slice(0,3);

  const today=dk(new Date());
  const daysRow=document.getElementById('cal-days-row');
  daysRow.innerHTML='<div style="background:rgba(0,0,0,0.15);"></div>';
  days.forEach(d=>{
    const h=document.createElement('div');
    h.className='cal-day-hdr'+(dk(d)===today?' today':'');
    h.innerHTML=dk(d)===today
      ?DAYS[d.getDay()]+'<br><span>'+d.getDate()+'</span>'
      :DAYS[d.getDay()]+'<br>'+d.getDate();
    daysRow.appendChild(h);
  });

  const body=document.getElementById('cal-body');
  body.innerHTML='';
  SLOTS.forEach((sl,si)=>{
    const row=document.createElement('div');
    row.className='cal-row';
    const tl=document.createElement('div');
    tl.className='time-lbl';
    tl.innerHTML='<span>'+sl.s+'</span><small>'+sl.e+'</small>';
    row.appendChild(tl);
    days.forEach(d=>{
      const cell=document.createElement('div');
      cell.className='slot-cell';
      const btn=document.createElement('button');
      const key=dk(d)+'_s'+si+'_c'+selCourt.id;
      if(isPast(d,si)){
        btn.className='slot-btn past';btn.textContent='—';btn.disabled=true;
      } else if(isTaken(d,si)){
        btn.className='slot-btn taken';btn.textContent='Ocupado';btn.disabled=true;
      } else {
        btn.className='slot-btn'+(selSlot&&selSlot.key===key?' sel':'');
        btn.textContent='Libre';
        btn.onclick=()=>selectSlot(d,si,key,btn);
      }
      cell.appendChild(btn);
      row.appendChild(cell);
    });
    body.appendChild(row);
  });
}

function selectSlot(d,si,key,btn){
  selSlot={date:d,si,key};
  document.querySelectorAll('.slot-btn.sel').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  btn.textContent='Seleccionado';
  document.getElementById('s-date').textContent=DAYS[d.getDay()]+' '+d.getDate()+' de '+MONTHS[d.getMonth()];
  document.getElementById('s-time').textContent=SLOTS[si].s+' – '+SLOTS[si].e;
  document.getElementById('s-price').textContent='$'+getPrice(selCourt.type,d).toLocaleString();
  document.getElementById('s-bk').textContent=getBk(selCourt.type,d);
  document.getElementById('booking-card').scrollIntoView({behavior:'smooth',block:'nearest'});
}

function selectCourt(el){
  document.querySelectorAll('.court-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  selCourt={id:el.dataset.id,name:el.dataset.name,type:el.dataset.type};
  document.getElementById('s-court').textContent=selCourt.name+' — '+(selCourt.type==='indoor'?'Indoor':'Outdoor');
  selSlot=null;
  document.getElementById('s-date').textContent='Elegí un día →';
  document.getElementById('s-time').textContent='—';
  const p=selCourt.type==='indoor'?1200:1040;
  document.getElementById('s-price').textContent='$'+p.toLocaleString();
  document.getElementById('s-bk').textContent=selCourt.type==='indoor'?'$300 × 4 personas':'$260 × 4 personas · lunes a viernes';
  renderCal();
}

function changeWeek(dir){
  if(weekOff+dir<0)return;
  weekOff+=dir;
  renderCal();
}

function doBooking(method){
  const name=document.getElementById('i-name').value.trim();
  const phone=document.getElementById('i-phone').value.trim();
  const email=document.getElementById('i-email').value.trim();
  const players=document.getElementById('i-players').value.trim();
  if(!selSlot){alert('Por favor seleccioná un horario en el calendario.');return;}
  if(!name){alert('Por favor ingresá tu nombre.');return;}
  if(!phone){alert('Por favor ingresá tu teléfono.');return;}

  const d=selSlot.date;
  const sl=SLOTS[selSlot.si];
  const price=getPrice(selCourt.type,d);
  const dateStr=DAYS[d.getDay()]+' '+d.getDate()+' de '+MONTHS[d.getMonth()];

  const booking={
    id:Date.now(),
    key:selSlot.key,
    courtId:selCourt.id,
    courtName:selCourt.name,
    courtType:selCourt.type,
    date:dk(d),
    dateStr,
    slot:sl.s+' – '+sl.e,
    name,phone,email,players,
    price,
    payMethod:method,
    cancelled:false,
    createdAt:new Date().toISOString()
  };

  reservas.push(booking);
  saveReservas();

  if(method==='mp'){
    // Reemplazá esta URL con tu preferencia de MercadoPago real
    window.open('https://www.mercadopago.com.uy/checkout/v1/redirect?pref_id=TU_PREFERENCE_ID','_blank');
  }

  document.getElementById('booking-card').style.display='none';
  const sc=document.getElementById('success-card');
  sc.style.display='block';
  document.getElementById('ok-title').textContent='¡Reserva confirmada, '+name+'!';
  document.getElementById('ok-detail').textContent=
    selCourt.name+' · '+dateStr+' · '+sl.s+' – '+sl.e+'\n$'+price.toLocaleString()+' UYU · '+(method==='mp'?'MercadoPago':'Pago en la cancha');

  const nr=document.getElementById('notif-row');
  nr.innerHTML='';

  const waAdmin=encodeURIComponent(
    '🎾 *Nueva reserva*\n👤 '+name+'\n📞 '+phone+(email?'\n📧 '+email:'')+
    '\n🏟 '+selCourt.name+' ('+selCourt.type+')\n📅 '+dateStr+'\n⏰ '+sl.s+' – '+sl.e+
    '\n💰 $'+price.toLocaleString()+' UYU\n💳 '+(method==='mp'?'MercadoPago':'Pago en cancha')+
    (players?'\n👥 '+players:'')
  );
  const waBtn=document.createElement('button');
  waBtn.className='notif-btn wa';
  waBtn.innerHTML='📲 Avisar al admin por WhatsApp';
  waBtn.onclick=()=>window.open('https://wa.me/'+WA_ADMIN.replace(/\D/g,'')+'?text='+waAdmin,'_blank');
  nr.appendChild(waBtn);

  if(email){
    const mailBtn=document.createElement('button');
    mailBtn.className='notif-btn';
    mailBtn.innerHTML='📧 Recibir confirmación por email';
    mailBtn.onclick=()=>{
      const sub='Reserva confirmada – '+selCourt.name+' · '+dateStr;
      const body='Hola '+name+',%0D%0A%0D%0ATu reserva en BioPadel está confirmada:%0D%0A%0D%0A🏟 Cancha: '+selCourt.name+'%0D%0A📅 Fecha: '+dateStr+'%0D%0A⏰ Horario: '+sl.s+' – '+sl.e+'%0D%0A💰 Total: $'+price.toLocaleString()+' UYU%0D%0A💳 Pago: '+(method==='mp'?'MercadoPago':'En la cancha')+'%0D%0A%0D%0A¡Nos vemos en la cancha!';
      window.open('mailto:'+email+'?subject='+encodeURIComponent(sub)+'&body='+body,'_blank');
    };
    nr.appendChild(mailBtn);
  }

  const newBtn=document.createElement('button');
  newBtn.className='notif-btn';
  newBtn.innerHTML='➕ Hacer otra reserva';
  newBtn.onclick=()=>{
    sc.style.display='none';
    document.getElementById('booking-card').style.display='block';
    ['i-name','i-phone','i-email','i-players'].forEach(id=>document.getElementById(id).value='');
    selSlot=null;
    document.getElementById('s-date').textContent='Elegí un día →';
    document.getElementById('s-time').textContent='—';
    renderCal();
    window.scrollTo({top:0,behavior:'smooth'});
  };
  nr.appendChild(newBtn);

  renderCal();
}

function renderAdmin(){
  const fc=document.getElementById('f-court').value;
  const fp=document.getElementById('f-pay').value;
  const fd=document.getElementById('f-date').value;

  let filtered=reservas.filter(r=>!r.cancelled);
  if(fc) filtered=filtered.filter(r=>r.courtId===fc);
  if(fp) filtered=filtered.filter(r=>r.payMethod===fp);
  if(fd) filtered=filtered.filter(r=>r.date===fd);
  filtered.sort((a,b)=>a.date.localeCompare(b.date)||a.slot.localeCompare(b.slot));

  const total=filtered.reduce((s,r)=>s+r.price,0);
  const mp=filtered.filter(r=>r.payMethod==='mp').length;
  const cash=filtered.filter(r=>r.payMethod==='cash').length;
  const todayStr=dk(new Date());
  const hoy=reservas.filter(r=>!r.cancelled&&r.date===todayStr).length;

  document.getElementById('stats-row').innerHTML=`
    <div class="stat-card"><div class="stat-lbl">Reservas (filtro actual)</div><div class="stat-val">${filtered.length}</div><div class="stat-sub">turnos</div></div>
    <div class="stat-card"><div class="stat-lbl">Hoy</div><div class="stat-val">${hoy}</div><div class="stat-sub">turnos del día</div></div>
    <div class="stat-card"><div class="stat-lbl">MP / Cancha</div><div class="stat-val">${mp} / ${cash}</div><div class="stat-sub">forma de pago</div></div>
    <div class="stat-card"><div class="stat-lbl">Total recaudado</div><div class="stat-val">$${total.toLocaleString()}</div><div class="stat-sub">UYU</div></div>
  `;

  const list=document.getElementById('res-list');
  if(filtered.length===0){
    list.innerHTML='<div class="empty-state"><div class="empty-state-icon">📭</div><p>No hay reservas para mostrar.<br>Las reservas aparecerán aquí al confirmarse.</p></div>';
    return;
  }

  list.innerHTML=filtered.map(r=>{
    const ini=r.name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
    const badgeCls=r.payMethod==='mp'?'badge-mp':'badge-cash';
    const badgeTxt=r.payMethod==='mp'?'💳 MercadoPago':'💵 En cancha';
    const waMsg=encodeURIComponent('📋 Recordatorio de tu reserva en BioPadel:\n👤 '+r.name+'\n🏟 '+r.courtName+'\n📅 '+r.dateStr+'\n⏰ '+r.slot);
    return `<div class="res-item">
      <div class="res-avatar">${ini}</div>
      <div class="res-info">
        <div class="res-name">${r.name}</div>
        <div class="res-meta">📅 ${r.dateStr} · ⏰ ${r.slot} · 🏟 ${r.courtName}</div>
        <div class="res-meta">📞 ${r.phone}${r.email?' · 📧 '+r.email:''}</div>
        ${r.players?'<div class="res-meta">👥 '+r.players+'</div>':''}
      </div>
      <div class="res-right">
        <div class="res-price">$${r.price.toLocaleString()}</div>
        <span class="res-badge ${badgeCls}">${badgeTxt}</span>
        <div class="res-actions">
          <a class="res-action-btn" href="https://wa.me/${WA_ADMIN.replace(/\D/g,'')}?text=${waMsg}" target="_blank" title="Enviar recordatorio">📲</a>
          <button class="res-action-btn danger" onclick="cancelar(${r.id})" title="Cancelar reserva">🗑</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function cancelar(id){
  if(!confirm('¿Cancelar esta reserva? El turno quedará libre.'))return;
  const r=reservas.find(x=>x.id===id);
  if(r){r.cancelled=true;saveReservas();renderCal();renderAdmin();}
}

function clearFilters(){
  document.getElementById('f-court').value='';
  document.getElementById('f-pay').value='';
  document.getElementById('f-date').value='';
  renderAdmin();
}

function switchView(v,btn){
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('view-'+v).classList.add('active');
  if(btn) btn.classList.add('active');
  if(v==='admin') renderAdmin();
}

function init(){
  loadReservas();
  renderCal();
  document.getElementById('f-date').value=dk(new Date());
}

init();
</script>
</body>
</html>
